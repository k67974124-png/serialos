{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@serialos/*": ["./packages/*/src/index.ts"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": ["*.config.ts", "apps/**/*.ts", "apps/**/*.tsx", "packages/**/*.ts", "tests/**/*.ts"]
}
