{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "env": [
        "AI_MAX_INPUT_TOKENS",
        "AI_MAX_OUTPUT_TOKENS",
        "AI_MAX_RETRIES_PER_STEP",
        "AI_MAX_WEB_SEARCH_CALLS",
        "AI_RUN_HARD_BUDGET_USD",
        "AI_RUN_SOFT_BUDGET_USD",
        "APP_URL",
        "DATABASE_URL",
        "JOB_DRAIN_TIMEOUT_SECONDS",
        "JOB_LOCK_SECONDS",
        "JOB_MAX_ATTEMPTS",
        "JOB_WORKER_CONCURRENCY",
        "LOG_LEVEL",
        "NODE_ENV",
        "S3_ACCESS_KEY_ID",
        "S3_BUCKET",
        "S3_ENDPOINT",
        "S3_FORCE_PATH_STYLE",
        "S3_REGION",
        "S3_SECRET_ACCESS_KEY",
        "WEB_PORT",
        "WORKER_HEALTH_HOST",
        "WORKER_HEALTH_PORT"
      ],
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
