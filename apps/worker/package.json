{
  "name": "@serialos/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file-if-exists=../../.env --import tsx --watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@serialos/application": "workspace:*",
    "@serialos/config": "workspace:*",
    "@serialos/db": "workspace:*",
    "@serialos/jobs": "workspace:*",
    "@serialos/observability": "workspace:*",
    "@serialos/storage": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
